{
    "name": "@bin-tracker/db",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./client": "./src/client.ts"
    },
    "scripts": {
        "generate": "prisma generate",
        "migrate:dev": "prisma migrate dev",
        "migrate:deploy": "prisma migrate deploy",
        "migrate:status": "prisma migrate status",
        "migrate:reset": "prisma migrate reset",
        "seed": "tsx --env-file=../../.env prisma/seed.ts",
        "seed:local": "tsx --env-file=../../.env prisma/seed.local.ts",
        "e2e": "tsx --env-file=../../.env e2e-test.ts",
        "studio": "prisma studio",
        "build": "tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist node_modules/.prisma"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "pg": "^8.18.0"
    },
    "devDependencies": {
        "@types/pg": "^8.16.0",
        "prisma": "^7.4.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}