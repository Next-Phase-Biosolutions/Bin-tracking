{
    "name": "@bin-tracker/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=../../.env src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/ --ext .ts",
        "lint:fix": "eslint src/ --ext .ts --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@bin-tracker/db": "workspace:*",
        "@bin-tracker/types": "workspace:*",
        "@bin-tracker/validators": "workspace:*",
        "@fastify/cors": "^10.0.0",
        "@fastify/helmet": "^13.0.0",
        "@fastify/rate-limit": "^10.2.0",
        "@prisma/client": "^7.4.0",
        "@supabase/ssr": "^0.8.0",
        "@trpc/server": "^11.0.0",
        "fastify": "^5.2.0",
        "jose": "^6.1.3",
        "pino": "^9.6.0",
        "superjson": "^2.2.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}