{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "strict": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "paths": {
            "@bin-tracker/types": ["../../packages/types/src/index.ts"],
            "@bin-tracker/validators": ["../../packages/validators/src/index.ts"]
        }
    },
    "include": ["src", "../api/src/routers"]
}
