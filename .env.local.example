# ─────────────────────────────────────────────────────────────────
#  .env.local.example — For local development WITHOUT Supabase or Docker
#
#  Prerequisites (Mac):
#   brew install postgresql@16
#   brew services start postgresql@16
#
#  Prerequisites (Windows):
#   Download and install from https://www.postgresql.org/download/windows/
#   Then start the PostgreSQL service from Services panel
#
#  One-time DB setup (run once in terminal):
#   createdb bin_tracker
#
#  Then:
#   1. cp .env.local.example .env
#   2. pnpm db:migrate               (run migrations)
#   3. pnpm db:seed:local            (seed without Supabase)
#   4. pnpm dev                      (start API + frontend)
#
#  Auth is fully disabled — the API auto-injects admin@bintracker.com
#  as the acting user for every request. No login required.
# ─────────────────────────────────────────────────────────────────

# ─── Database (local native Postgres — no Docker needed) ─────────
# Format: postgresql://<user>:<password>@localhost:5432/<dbname>
# Default postgres superuser has no password on most local installs.
# If your local postgres has a password, update accordingly.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bin_tracker"
# Common alternatives depending on your local setup:
# DATABASE_URL="postgresql://postgres@localhost:5432/bin_tracker"        # no password
# DATABASE_URL="postgresql://johndoe:mypassword@localhost:5432/bin_tracker"

# ─── Supabase — NOT required in local mode ───────────────────────
# Leave these blank. Auth is disabled via DISABLE_AUTH=true below.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ─── Auth bypass — REQUIRED for local mode ───────────────────────
# Disables all JWT checks. API injects first ADMIN user automatically.
# NEVER set this to true in production.
DISABLE_AUTH=true
VITE_DISABLE_AUTH=true

# ─── Seed safety guard (matches masumi-payment-service pattern) ───
# Prevents accidental data wipe if seed is run a second time.
# Set to false only if you intentionally want to re-seed from scratch.
SEED_ONLY_IF_EMPTY=true

# ─── API Server ──────────────────────────────────────────────────
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── Cardano — optional, leave blank to skip blockchain features ─
BLOCKFROST_API_KEY=""
CARDANO_NETWORK="preprod"
CARDANO_NFT_IMAGE_CID=""

VITE_BLOCKFROST_API_KEY=""
VITE_CARDANO_NETWORK="preprod"
VITE_CARDANO_SCAN_BASE_URL="https://preprod.cardanoscan.io/transaction"

# ─── Test tokens — not needed in local mode ──────────────────────
VITE_TEST_DRIVER_TOKEN=""
VITE_TEST_ADMIN_TOKEN=""
VITE_TEST_STATION_TOKEN=""
