# ─── Database ───────────────────────────────────────────
# Supabase connection pooler URL (recommended) or a direct Postgres URL
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres?pgbouncer=true&connection_limit=1"

# ─── Supabase ──────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# ─── Vite / Frontend ───────────────────────────────────
# These must be prefixed with VITE_ to be exposed to the browser
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ─── API Server ────────────────────────────────────────
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"

# Set to true to bypass all auth checks — DEV / TEST ONLY, never in production
DISABLE_AUTH=false
VITE_DISABLE_AUTH=false

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── Cardano ──────────────────────────────────────────
# Server-side Blockfrost key (used by API if needed)
BLOCKFROST_API_KEY=""
CARDANO_NETWORK="preprod"
CARDANO_NFT_IMAGE_CID=""

# Frontend (Vite) — use a read-only Blockfrost project key here
VITE_BLOCKFROST_API_KEY=""
VITE_CARDANO_NETWORK="preprod"
VITE_CARDANO_SCAN_BASE_URL="https://preprod.cardanoscan.io/transaction"

# ─── Auth Tokens (MVP / Local Testing Only) ───────────
# Generate these from your Supabase project for local development.
# Never commit real long-lived tokens to version control.
VITE_TEST_DRIVER_TOKEN=""
VITE_TEST_ADMIN_TOKEN=""
VITE_TEST_STATION_TOKEN=""
